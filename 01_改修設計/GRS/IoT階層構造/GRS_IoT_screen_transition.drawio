        </mxCell>
        <mxCell id="21" parent="1" style="rounded=1;arcSize=5;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#ffe082;fontSize=12;align=left;verticalAlign=top;spacingLeft=12;spacingTop=12;spacingRight=12;shadow=1;fontColor=#333333;" value="&lt;b style=&quot;font-size:14px;color:#f57f17;&quot;&gt;登録ダイアログ [新規モード]&lt;/b&gt;&lt;hr size=&quot;1&quot; color=&quot;#ffecb3&quot;/&gt;① &lt;b&gt;本社情報:&lt;/b&gt; 管理用UNISCD* / 本社名*（入力可）&lt;br&gt;　 サービスCD（任意）: neos_contracts確認用&lt;br&gt;② &lt;b&gt;DX企業情報:&lt;/b&gt; DX企業名*（入力可）&lt;br&gt;　 ※DX企業CDは自動発番&lt;br&gt;③ &lt;b&gt;支店情報:&lt;/b&gt; 顧客CD* / サービスCD*（入力可）&lt;br&gt;&lt;hr size=&quot;1&quot; color=&quot;#ffecb3&quot;/&gt;[キャンセル]　[登録実行]（必須入力後活性化）" vertex="1">
