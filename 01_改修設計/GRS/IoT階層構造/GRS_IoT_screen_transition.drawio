        <mxCell id="30" parent="1" style="rounded=1;arcSize=5;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#90caf9;fontSize=12;align=left;verticalAlign=top;spacingLeft=12;spacingTop=12;spacingRight=12;shadow=1;fontColor=#333333;" value="&lt;b style=&quot;font-size:13px;color:#1565c0;&quot;&gt;候補一覧（名前検索・複数ヒット）&lt;/b&gt;&lt;hr size=&quot;1&quot; color=&quot;#bbdefb&quot;/&gt;「複数の本社が該当（N件）」&lt;br&gt;本社名（太字）/ 本社CD / 顧客CD を一覧表示&lt;br&gt;&lt;br&gt;アクション: &lt;b&gt;[この本社を表示]&lt;/b&gt; ボタン" vertex="1">
